{
  "name": "@compasser/design-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./components": "./src/components/index.ts",
    "./icons": "./src/icons/index.ts",
    "./utils": "./src/libs/index.ts",
    "./styles.css": "./styles.css"
  },
  "scripts": {
    "icons:clean": "svgo -r -f src/icons/source --config=./svgo.config.mjs --multipass",
    "icons:gen": "pnpm dlx tsx src/icons/scripts/generate-icons.ts",
    "icons": "pnpm run icons:clean && pnpm run icons:gen",
    "generate:icons": "pnpm run icons",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "dev:storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "predev:storybook": "pnpm run icons",
    "prebuild:storybook": "pnpm run icons"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "dependencies": {
    "@compasser/tailwind-config": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.4.1"
  },
  "devDependencies": {
    "@compasser/typescript-config": "workspace:*",
    "@storybook/react-vite": "9.1.3",
    "@tailwindcss/vite": "^4.2.1",
    "storybook": "9.1.3",
    "svgo": "^4.0.1",
    "tailwindcss": "^4.1.12",
    "typescript": "5.9.2",
    "vite": "^7.3.1"
  }
}
